# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Price IDs — create products in the Stripe dashboard, then paste their price IDs
STRIPE_PRICE_SERVICE_DOG=price_...
STRIPE_PRICE_BEHAVIORAL=price_...
STRIPE_PRICE_HANDLER=price_...
STRIPE_PRICE_HANDLER_PLAN=price_...   # payment plan variant

# ── Site ──────────────────────────────────────────────────────────────────────
# Used to build success/cancel redirect URLs in Stripe Checkout
NEXT_PUBLIC_SITE_URL=https://www.serafimdogtraining.com

# ── Calendly ─────────────────────────────────────────────────────────────────
# Paste the embed URL from your Calendly event
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/YOUR_HANDLE/consult

# ── Skool ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SKOOL_URL=https://www.skool.com/YOUR_COMMUNITY
